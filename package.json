{
  "name": "ccsquad",
  "version": "1.1.0",
  "description": "A shared communication channel for Claude Code instances — a Slack channel for agents.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "ccsquad": "dist/cli.js"
  },
  "files": [
    "dist/",
    "skills/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["claude", "claude-code", "mcp", "agents", "ai", "coordination", "multi-agent"],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rmotgi1227/ClaudeSquad.git"
  },
  "homepage": "https://github.com/rmotgi1227/ClaudeSquad#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
